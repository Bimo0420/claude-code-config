# Claude internal data - exclude by default
.claude/
# Allow specific config files
!.claude/settings.json
!.claude/channels/
!.claude/channels/telegram/
!.claude/channels/telegram/access.json
!.claude/channels/telegram/approved

# Always exclude secrets and session data
.claude/.credentials.json
.claude/projects/
.claude/sessions/
.claude/cache/
.claude/backups/
.claude/plugins/
.claude/downloads/
.claude/file-history/
.claude/shell-snapshots/
.claude/telemetry/
.claude/ide/

# Shell & system
.bash_history
.bashrc
.profile
.viminfo
.wget-hsts
.cache/
.local/
.config/
.dotnet/
.bun/
.vscode-server/
.copilot/

# Secrets
.env
*.env
